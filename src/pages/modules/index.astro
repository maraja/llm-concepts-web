---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { modules } from '../../data/modules';
---

<BaseLayout title="All Modules">
  <Header />
  <main class="mx-auto max-w-[900px] px-4 sm:px-6 py-10 sm:py-16">
    <header class="mb-14">
      <h1 class="font-serif text-[1.75rem] sm:text-[2.5rem] font-bold text-forest-700 tracking-tight mb-3">All Modules</h1>
      <p class="text-lg text-forest-500 max-w-lg leading-relaxed">
        156 concepts across 11 modules &mdash; from transformer fundamentals to cutting-edge research.
      </p>
    </header>

    <div class="space-y-3">
      {modules.map(mod => {
        const isActive = ['01', '02', '03', '04'].includes(mod.number);
        return isActive ? (
          <a
            href={`/modules/${mod.slug}`}
            class="group flex items-start gap-5 rounded-xl border border-cream-300 bg-cream-50/80 p-6 transition-all hover:border-sage/40 hover:bg-white hover:shadow-sm no-underline"
          >
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-sage/10 flex items-center justify-center text-xl">
              {mod.icon}
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="text-[11px] font-mono text-forest-400">Module {mod.number}</span>
                <span class="inline-flex items-center rounded-full bg-sage/12 px-2 py-0.5 text-[10px] font-semibold text-sage-dark">
                  {mod.conceptCount} concepts
                </span>
                <span class="inline-flex items-center rounded-full bg-rust/8 px-2 py-0.5 text-[10px] font-semibold text-rust">
                  Available
                </span>
              </div>
              <h3 class="font-serif text-lg font-semibold text-forest-700 group-hover:text-rust transition-colors">
                {mod.title}
              </h3>
              <p class="text-sm text-forest-500 mt-1 leading-relaxed">{mod.description}</p>
            </div>
            <svg class="w-5 h-5 text-forest-400/40 group-hover:text-rust transition-all flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ) : (
          <div class="flex items-start gap-5 rounded-xl border border-cream-300/40 bg-cream-100/30 p-6 opacity-45">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-cream-200/50 flex items-center justify-center text-xl">
              {mod.icon}
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="text-[11px] font-mono text-forest-400">Module {mod.number}</span>
                <span class="inline-flex items-center rounded-full bg-cream-200/60 px-2 py-0.5 text-[10px] font-medium text-forest-400">
                  {mod.conceptCount} concepts
                </span>
              </div>
              <h3 class="font-serif text-lg font-semibold text-forest-600">{mod.title}</h3>
              <p class="text-sm text-forest-400 mt-1">{mod.description}</p>
            </div>
          </div>
        );
      })}
    </div>
  </main>
  <Footer />
</BaseLayout>

---
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Modules', href: '/modules' },
];
---

<header class="sticky top-0 z-50 bg-cream-100/90 backdrop-blur-md border-b border-cream-300/70">
  <div class="mx-auto flex max-w-[1200px] items-center justify-between px-6 h-14">
    <a href="/" class="flex items-center gap-2.5 no-underline group">
      <span class="flex items-center justify-center w-7 h-7 rounded-md bg-forest-700 text-cream-100 font-serif font-bold text-sm">L</span>
      <span class="font-serif text-lg font-semibold text-forest-700 tracking-tight group-hover:text-rust transition-colors">LLM Concepts</span>
    </a>

    <nav class="flex items-center gap-1">
      {navItems.map(item => (
        <a
          href={item.href}
          class="px-3 py-1.5 text-xs font-mono text-forest-500 rounded-md hover:text-forest-700 hover:bg-cream-200/60 transition-all no-underline tracking-wide"
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

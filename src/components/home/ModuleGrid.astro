---
import { modules } from '../../data/modules';
---

<section class="mx-auto max-w-[900px] px-6 pb-24">
  <div class="mb-12">
    <h2 class="font-serif text-2xl font-bold text-forest-700 mb-2">Curriculum</h2>
    <p class="text-forest-500 text-[15px] max-w-lg">
      A structured path through the ideas that power modern language models.
    </p>
  </div>

  <div class="space-y-3">
    {modules.map((mod, i) => (
      <a
        href={`/modules/${mod.slug}`}
        class="group flex items-start gap-5 rounded-xl border border-cream-300 bg-cream-50/80 p-5 sm:p-6 transition-all hover:border-sage/40 hover:bg-white hover:shadow-sm no-underline"
      >
        <div class="flex-shrink-0 w-11 h-11 sm:w-12 sm:h-12 rounded-xl bg-sage/10 flex items-center justify-center text-xl">
          {mod.icon}
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1.5 flex-wrap">
            <span class="text-[11px] font-mono font-medium text-forest-400">Module {mod.number}</span>
            <span class="inline-flex items-center rounded-full bg-sage/12 px-2.5 py-0.5 text-[10px] font-semibold text-sage-dark tracking-wide">
              {mod.conceptCount} concepts
            </span>
            {i === 0 && (
              <span class="inline-flex items-center rounded-full bg-rust/8 px-2.5 py-0.5 text-[10px] font-semibold text-rust tracking-wide">
                Start here
              </span>
            )}
          </div>
          <h3 class="font-serif text-base sm:text-lg font-semibold text-forest-700 group-hover:text-rust transition-colors leading-snug">
            {mod.title}
          </h3>
          <p class="text-[13px] sm:text-sm text-forest-500 mt-1 leading-relaxed line-clamp-2">{mod.description}</p>
        </div>
        <svg class="w-5 h-5 text-forest-400/30 group-hover:text-rust group-hover:translate-x-0.5 transition-all flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    ))}
  </div>
</section>

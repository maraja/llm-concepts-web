---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import { render } from 'astro:content';
import { modules, getModule } from '../../data/modules';
import { formatConceptName } from '../../utils/slugify';
import { getConceptOrder, getModuleConcepts } from '../../utils/concepts';

export function getStaticPaths() {
  return [
    { params: { module: 'foundational-architecture' } },
    { params: { module: 'input-representation' } },
    { params: { module: 'training-fundamentals' } },
    { params: { module: 'distributed-training' } },
  ];
}

const { module: moduleSlug } = Astro.params;
const mod = getModule(moduleSlug!);

if (!mod) {
  return Astro.redirect('/modules');
}

const moduleConcepts = await getModuleConcepts(moduleSlug!);
const order = getConceptOrder(moduleSlug!);

// Render each concept to extract metadata from remark plugin
const conceptsWithMeta = await Promise.all(
  moduleConcepts.map(async (concept) => {
    const { remarkPluginFrontmatter } = await render(concept);
    return {
      ...concept,
      title: remarkPluginFrontmatter?.title || formatConceptName(concept.slug),
      summary: remarkPluginFrontmatter?.summary || '',
    };
  })
);

// Sort concepts according to defined order
const sortedConcepts = conceptsWithMeta.sort((a, b) => {
  const idxA = order.indexOf(a.slug);
  const idxB = order.indexOf(b.slug);
  if (idxA === -1 && idxB === -1) return a.slug.localeCompare(b.slug);
  if (idxA === -1) return 1;
  if (idxB === -1) return -1;
  return idxA - idxB;
});

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Modules', href: '/modules' },
  { label: mod.title, href: '' },
];
---

<BaseLayout title={mod.title} description={mod.description}>
  <Header />
  <main class="mx-auto max-w-[900px] px-4 sm:px-6 py-10 sm:py-16">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mb-14">
      <div class="flex items-center gap-3 mb-5">
        <span class="text-3xl">{mod.icon}</span>
        <div class="flex items-center gap-2">
          <span class="text-[11px] font-mono text-forest-400">Module {mod.number}</span>
          <span class="inline-flex items-center rounded-full bg-sage/12 px-2.5 py-0.5 text-[10px] font-semibold text-sage-dark tracking-wide">
            {sortedConcepts.length} concepts
          </span>
        </div>
      </div>
      <h1 class="font-serif text-[1.75rem] sm:text-[2.5rem] font-bold text-forest-700 tracking-tight mb-3">{mod.title}</h1>
      <p class="text-lg text-forest-500 max-w-lg leading-relaxed">{mod.description}</p>
    </header>

    <!-- Concept list -->
    <div class="space-y-2">
      {sortedConcepts.map((concept, i) => (
          <a
            href={`/concepts/${moduleSlug}/${concept.slug}`}
            class="group flex items-start gap-4 rounded-xl border border-cream-300/80 bg-cream-50/60 p-5 transition-all hover:border-sage/40 hover:bg-white hover:shadow-sm no-underline"
          >
            <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-cream-200/80 flex items-center justify-center text-[11px] font-mono font-semibold text-forest-400">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class="flex-1 min-w-0">
              <h3 class="font-serif text-[15px] font-semibold text-forest-700 group-hover:text-rust transition-colors leading-snug">
                {concept.title}
              </h3>
              {concept.summary && (
                <p class="text-[13px] text-forest-500 mt-1.5 line-clamp-2 leading-relaxed">{concept.summary}</p>
              )}
            </div>
            <svg class="w-4 h-4 text-forest-400/30 group-hover:text-rust group-hover:translate-x-0.5 transition-all flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>

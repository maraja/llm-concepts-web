<section class="relative py-16 sm:py-24 md:py-32 overflow-hidden">
  <!-- Soft gradient orbs -->
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute -top-20 left-1/3 w-[400px] h-[400px] bg-sage/[0.04] rounded-full blur-[100px]"></div>
    <div class="absolute -bottom-10 right-1/4 w-[300px] h-[300px] bg-rust/[0.03] rounded-full blur-[80px]"></div>
  </div>

  <div class="mx-auto max-w-[680px] text-center px-6">
    <div class="inline-flex items-center gap-2 rounded-full border border-sage/20 bg-sage/[0.06] px-4 py-1.5 text-[12px] font-mono font-medium text-sage-dark mb-8 tracking-wide">
      <span class="w-1.5 h-1.5 rounded-full bg-sage"></span>
      156 concepts &middot; 11 modules
    </div>

    <h1 class="font-serif text-[2.25rem] sm:text-[3.25rem] md:text-[3.75rem] font-bold text-forest-700 leading-[1.1] tracking-tight mb-6">
      Understanding Large Language Models
    </h1>

    <p class="text-lg text-forest-500 leading-relaxed max-w-[520px] mx-auto mb-10">

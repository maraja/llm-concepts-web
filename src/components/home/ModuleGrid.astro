---
import { modules } from '../../data/modules';

const activeModules = modules.filter(m => m.number === '01');
const upcomingModules = modules.filter(m => m.number !== '01');
---

<section class="mx-auto max-w-[900px] px-6 pb-24">
  <div class="mb-12">
    <h2 class="font-serif text-2xl font-bold text-forest-700 mb-2">Curriculum</h2>
    <p class="text-forest-500 text-[15px] max-w-lg">
      A structured path through the ideas that power modern language models.
    </p>
  </div>

  <!-- Active module: featured card -->
  <div class="mb-16">
    {activeModules.map(mod => (
      <a
        href={`/modules/${mod.slug}`}
        class="group block rounded-2xl border border-cream-300 bg-cream-50/80 p-8 transition-all hover:border-sage/40 hover:bg-white hover:shadow-sm no-underline"
      >
        <div class="flex items-start gap-6">
          <div class="flex-shrink-0 w-14 h-14 rounded-xl bg-sage/10 flex items-center justify-center text-2xl">
            {mod.icon}
          </div>
          <div class="flex-1">
            <div class="flex items-center gap-2.5 mb-2">
              <span class="text-[11px] font-mono font-medium text-forest-400">Module {mod.number}</span>
              <span class="inline-flex items-center rounded-full bg-sage/12 px-2.5 py-0.5 text-[10px] font-semibold text-sage-dark tracking-wide">
                {mod.conceptCount} concepts
              </span>
              <span class="inline-flex items-center rounded-full bg-rust/8 px-2.5 py-0.5 text-[10px] font-semibold text-rust tracking-wide">
                Start here
              </span>
            </div>
            <h3 class="font-serif text-xl font-semibold text-forest-700 group-hover:text-rust transition-colors mb-2">
              {mod.title}
            </h3>
            <p class="text-sm text-forest-500 leading-relaxed">{mod.description}</p>
          </div>
          <svg class="w-5 h-5 text-forest-400/50 group-hover:text-rust group-hover:translate-x-0.5 transition-all flex-shrink-0 mt-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </div>
      </a>
    ))}
  </div>

  <!-- Upcoming modules -->
  <div>
    <p class="text-[10px] font-semibold uppercase tracking-[0.15em] text-forest-400 mb-5">Coming soon</p>
    <div class="grid sm:grid-cols-2 gap-3">
      {upcomingModules.map(mod => (
        <div class="flex items-start gap-3 rounded-xl border border-cream-300/50 bg-cream-100/40 p-4 opacity-50">
          <span class="text-lg mt-0.5">{mod.icon}</span>
          <div>
            <p class="text-[11px] font-mono text-forest-400 mb-0.5">Module {mod.number}</p>
            <p class="font-serif text-[14px] font-semibold text-forest-600 leading-snug">{mod.title}</p>
            <p class="text-[11px] text-forest-400 mt-1">{mod.conceptCount} concepts</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
